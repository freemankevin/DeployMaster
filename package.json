{
  "name": "deploymaster",
  "version": "1.0.0",
  "description": "DeployMaster - 自动化部署平台",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "server": "cd backend && python main.py",
    "start": "npm run build && concurrently \"npm run dev\" \"npm run server\"",
    "init-db": "cd backend && python main.py --init-db"
  },
  "keywords": [
    "ssh",
    "management",
    "deployment",
    "automation",
    "react",
    "fastapi"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@fortawesome/fontawesome-free": "^7.2.0",
    "@tabler/icons-webfont": "^3.36.0",
    "@xterm/addon-fit": "^0.9.0",
    "@xterm/addon-unicode11": "^0.9.0",
    "@xterm/addon-webgl": "^0.19.0",
    "@xterm/xterm": "^5.3.0",
    "axios": "^1.6.2",
    "clsx": "^2.0.0",
    "lucide-react": "^0.294.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.20.0"
  },
  "devDependencies": {
    "@types/react": "^18.2.43",
    "@types/react-dom": "^18.2.17",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.16",
    "concurrently": "^8.2.2",
    "postcss": "^8.4.32",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.3.3",
    "vite": "^5.0.8"
  }
}
